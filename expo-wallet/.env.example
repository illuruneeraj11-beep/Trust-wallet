# Connected wallet ledger (recommended for shared mobile QA).
EXPO_PUBLIC_WALLET_MODE=connected
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Connected mode requires the Supabase public values above. For isolated visual-only
# development, set EXPO_PUBLIC_WALLET_MODE=visual-demo.

# Server-only: configure on Vercel Preview and Production. Never prefix with EXPO_PUBLIC_.
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key

# Optional for installed native builds. Web builds use same-origin /api routes.
EXPO_PUBLIC_MARKET_API_BASE_URL=https://expo-wallet.vercel.app
